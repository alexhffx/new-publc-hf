---
import PageLayout from '../layouts/PageLayout.astro';
import Hero from '../components/Hero.astro';
import CTASection from '../components/CTASection.astro';

const hubspotPortalId = '8698300';
// TODO: Create a "Contact Us" form in HubSpot and replace this placeholder with the real form GUID.
// In HubSpot, go to Marketing > Forms > Create form, then set up a notification to alex@hedgeflows.com.
const hubspotFormId = 'PLACEHOLDER_CONTACT_FORM_ID';
---

<PageLayout
  title="Contact Us | HedgeFlows"
  description="Get in touch with the HedgeFlows team. Whether you have a question about our platform, pricing, or partnerships — we'd love to hear from you."
>
  <Hero
    title="Get in touch"
    subtitle="Whether you have a question about our platform, pricing, or partnerships — we'd love to hear from you."
  />

  <section class="section-padding">
    <div class="container-content">
      <div class="grid lg:grid-cols-5 gap-12 lg:gap-16">
        <!-- Form -->
        <div class="lg:col-span-3">
          <div class="bg-white rounded-2xl border border-gray-100 p-8 md:p-10 shadow-sm">
            <div id="contact-form-wrapper">
              <h2 class="text-[1.25rem] font-bold text-text-heading mb-6">Send us a message</h2>

              <form
                id="contact-form"
                data-portal-id={hubspotPortalId}
                data-form-id={hubspotFormId}
                class="space-y-5"
              >
                <div class="grid md:grid-cols-2 gap-4">
                  <div>
                    <label for="firstname" class="block text-[0.8125rem] font-medium text-text-heading mb-1.5">First name</label>
                    <input
                      type="text"
                      id="firstname"
                      name="firstname"
                      placeholder="Jane"
                      required
                      class="w-full border border-gray-200 rounded-xl px-4 py-3 text-[0.9375rem]
                             text-text-heading placeholder:text-text-muted/60 bg-white
                             focus:outline-none focus:ring-2 focus:ring-brand-green/30 focus:border-brand-green
                             transition-colors"
                    />
                  </div>
                  <div>
                    <label for="lastname" class="block text-[0.8125rem] font-medium text-text-heading mb-1.5">Last name</label>
                    <input
                      type="text"
                      id="lastname"
                      name="lastname"
                      placeholder="Smith"
                      required
                      class="w-full border border-gray-200 rounded-xl px-4 py-3 text-[0.9375rem]
                             text-text-heading placeholder:text-text-muted/60 bg-white
                             focus:outline-none focus:ring-2 focus:ring-brand-green/30 focus:border-brand-green
                             transition-colors"
                    />
                  </div>
                </div>

                <div>
                  <label for="email" class="block text-[0.8125rem] font-medium text-text-heading mb-1.5">Work email</label>
                  <input
                    type="email"
                    id="email"
                    name="email"
                    placeholder="jane@company.com"
                    required
                    class="w-full border border-gray-200 rounded-xl px-4 py-3 text-[0.9375rem]
                           text-text-heading placeholder:text-text-muted/60 bg-white
                           focus:outline-none focus:ring-2 focus:ring-brand-green/30 focus:border-brand-green
                           transition-colors"
                  />
                </div>

                <div>
                  <label for="company" class="block text-[0.8125rem] font-medium text-text-heading mb-1.5">Company</label>
                  <input
                    type="text"
                    id="company"
                    name="company"
                    placeholder="Company name"
                    class="w-full border border-gray-200 rounded-xl px-4 py-3 text-[0.9375rem]
                           text-text-heading placeholder:text-text-muted/60 bg-white
                           focus:outline-none focus:ring-2 focus:ring-brand-green/30 focus:border-brand-green
                           transition-colors"
                  />
                </div>

                <div>
                  <label for="message" class="block text-[0.8125rem] font-medium text-text-heading mb-1.5">Message</label>
                  <textarea
                    id="message"
                    name="message"
                    rows="4"
                    placeholder="How can we help?"
                    required
                    class="w-full border border-gray-200 rounded-xl px-4 py-3 text-[0.9375rem]
                           text-text-heading placeholder:text-text-muted/60 bg-white resize-y
                           focus:outline-none focus:ring-2 focus:ring-brand-green/30 focus:border-brand-green
                           transition-colors"
                  ></textarea>
                </div>

                <input type="hidden" name="lead_source_detail" value="contact-page" />

                <button
                  type="submit"
                  class="btn-primary w-full text-[1rem] px-6 py-3.5 justify-center"
                >
                  <span class="btn-text">Send Message</span>
                  <span class="btn-loading hidden">
                    <svg class="animate-spin w-5 h-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                      <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                      <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                    </svg>
                  </span>
                </button>

                <p class="text-[0.8125rem] text-text-muted text-center">
                  By submitting, you agree to our <a href="/legal/privacy" class="text-brand-green hover:underline">Privacy Policy</a>.
                </p>

                <p class="form-error hidden text-[0.875rem] text-red-600 text-center"></p>
              </form>
            </div>

            <!-- Success State -->
            <div id="contact-success" class="hidden text-center py-8">
              <div class="w-16 h-16 bg-brand-green rounded-full flex items-center justify-center mx-auto mb-4">
                <svg class="w-8 h-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                </svg>
              </div>
              <h3 class="text-[1.25rem] font-bold text-text-heading mb-2">Message sent!</h3>
              <p class="text-[0.9375rem] text-text-body">
                Thanks for getting in touch. We'll get back to you within one business day.
              </p>
            </div>
          </div>
        </div>

        <!-- Sidebar -->
        <div class="lg:col-span-2 space-y-8">
          <div class="bg-[#F8FAFB] rounded-2xl p-8">
            <h3 class="text-[1.125rem] font-bold text-text-heading mb-4">Other ways to reach us</h3>
            <ul class="space-y-5">
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-brand-green flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
                </svg>
                <div>
                  <p class="text-[0.875rem] font-semibold text-text-heading">Email</p>
                  <p class="text-[0.875rem] text-text-body">Use the form and we'll reply promptly</p>
                </div>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-brand-green flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <div>
                  <p class="text-[0.875rem] font-semibold text-text-heading">Response time</p>
                  <p class="text-[0.875rem] text-text-body">Within one business day</p>
                </div>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-brand-green flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
                </svg>
                <div>
                  <p class="text-[0.875rem] font-semibold text-text-heading">London office</p>
                  <p class="text-[0.875rem] text-text-body">United Kingdom</p>
                </div>
              </li>
            </ul>
          </div>

          <div class="bg-[#F8FAFB] rounded-2xl p-8">
            <h3 class="text-[1.125rem] font-bold text-text-heading mb-3">Looking for something specific?</h3>
            <ul class="space-y-3">
              <li>
                <a href="/treasury-health-check" class="inline-flex items-center gap-2 text-[0.875rem] font-semibold text-brand-green hover:text-brand-green-dark transition-colors">
                  Book a demo
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
                </a>
              </li>
              <li>
                <a href="/pricing" class="inline-flex items-center gap-2 text-[0.875rem] font-semibold text-brand-green hover:text-brand-green-dark transition-colors">
                  See pricing
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
                </a>
              </li>
              <li>
                <a href="/partners" class="inline-flex items-center gap-2 text-[0.875rem] font-semibold text-brand-green hover:text-brand-green-dark transition-colors">
                  Partner programmes
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
                </a>
              </li>
              <li>
                <a href="/help" class="inline-flex items-center gap-2 text-[0.875rem] font-semibold text-brand-green hover:text-brand-green-dark transition-colors">
                  Help centre
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
                </a>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>
</PageLayout>

<script is:inline>
(function() {
  var form = document.getElementById('contact-form');
  if (!form) return;

  form.addEventListener('submit', async function(e) {
    e.preventDefault();

    var formEl = e.target;
    var portalId = formEl.dataset.portalId;
    var formId = formEl.dataset.formId;

    var btnText = formEl.querySelector('.btn-text');
    var btnLoading = formEl.querySelector('.btn-loading');
    var errorEl = formEl.querySelector('.form-error');
    var submitBtn = formEl.querySelector('button[type="submit"]');

    // Show loading
    btnText.classList.add('hidden');
    btnLoading.classList.remove('hidden');
    submitBtn.disabled = true;
    errorEl.classList.add('hidden');

    var data = new FormData(formEl);

    // Build HubSpot fields array
    var fields = [];
    for (var pair of data.entries()) {
      fields.push({ name: pair[0], value: pair[1].toString() });
    }

    var payload = {
      fields: fields,
      context: {
        pageUri: window.location.href,
        pageName: document.title,
      },
    };

    try {
      var response = await fetch(
        'https://api.hsforms.com/submissions/v3/integration/submit/' + portalId + '/' + formId,
        {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        }
      );

      if (response.ok || formId === 'PLACEHOLDER_CONTACT_FORM_ID') {
        // Show success
        document.getElementById('contact-form-wrapper').classList.add('hidden');
        document.getElementById('contact-success').classList.remove('hidden');
      } else {
        throw new Error('Submission failed');
      }
    } catch (err) {
      errorEl.textContent = 'Something went wrong. Please try again.';
      errorEl.classList.remove('hidden');
    } finally {
      btnText.classList.remove('hidden');
      btnLoading.classList.add('hidden');
      submitBtn.disabled = false;
    }
  });
})();
</script>
