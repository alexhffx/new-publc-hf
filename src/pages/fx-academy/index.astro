---
import PageLayout from '../../layouts/PageLayout.astro';
import Hero from '../../components/Hero.astro';
import BlogCard from '../../components/BlogCard.astro';
import { getCollection } from 'astro:content';
import {
  fxAcademyPillars,
  hubGlossaryTerms,
  hubHelpPages,
  hubProductLinks,
} from '../../data/hubPages';

/* ── Fetch blog posts for FX hedging + currency management pillars ── */
const allPosts = await getCollection('blog');
const pillarPosts = allPosts
  .filter((p) => p.data.pillar && fxAcademyPillars.includes(p.data.pillar))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 12);

/* ── Fetch glossary terms to resolve display names ── */
const allGlossary = await getCollection('glossary');
const glossarySlugs = hubGlossaryTerms['fx-academy'] || [];
const glossaryTerms = glossarySlugs
  .map((slug) => allGlossary.find((g) => g.data.slug === slug))
  .filter(Boolean) as typeof allGlossary;

const helpPages = hubHelpPages['fx-academy'] || [];
const productLinks = hubProductLinks['fx-academy'] || [];

const guides = [
  {
    title: 'Foreign Exchange 101',
    slug: 'foreign-exchange-101',
    description: 'What is an FX transaction? How do FX markets work? What are different types of currencies and what moves them?',
    readingTime: '12 min read',
    level: 'Beginner',
  },
  {
    title: 'FX Markets & Financial Instruments',
    slug: 'fx-markets-and-instruments',
    description: 'Where do FX prices come from? What are spot, forward, swap, and option contracts? How to access FX markets at any business size.',
    readingTime: '14 min read',
    level: 'Beginner',
  },
  {
    title: 'Paying Overseas for Growing Businesses',
    slug: 'paying-overseas',
    description: 'Payment methods, hidden FX costs, manual process risks, and fraud prevention for international payments.',
    readingTime: '11 min read',
    level: 'Beginner',
  },
  {
    title: 'Currency Management for Growing Businesses',
    slug: 'currency-management',
    description: 'A structured approach to identifying, quantifying, and managing FX risks as your international business scales.',
    readingTime: '13 min read',
    level: 'Intermediate',
  },
  {
    title: 'Balance Sheet Hedging',
    slug: 'balance-sheet-hedging',
    description: 'How to set hedging objectives, design a process, and manage FX risks that affect your balance sheet and reported earnings.',
    readingTime: '14 min read',
    level: 'Intermediate',
  },
  {
    title: 'Mastering FX Cashflow Hedging',
    slug: 'cashflow-hedging',
    description: 'Understand the difference between cashflow and balance sheet hedging, and build a framework to protect your future revenues and costs.',
    readingTime: '15 min read',
    level: 'Advanced',
  },
  {
    title: 'How to Construct a Hedging Programme',
    slug: 'hedging-programme',
    description: 'A 10-step guide to building an effective FX hedging programme that fits your business and gets stakeholder buy-in.',
    readingTime: '16 min read',
    level: 'Advanced',
  },
  {
    title: 'Emerging Market FX',
    slug: 'emerging-markets',
    description: 'Managing currency risk in high-growth economies — from capital controls and volatile currencies to NDFs and trapped cash.',
    readingTime: '14 min read',
    level: 'Advanced',
  },
  {
    title: 'Structured FX Products',
    slug: 'structured-fx-products',
    description: 'Participating forwards, accumulators, TARFs, and knock-in/knock-out structures — what they are, how they work, and when they make sense.',
    readingTime: '16 min read',
    level: 'Advanced',
  },
];

const levelColors: Record<string, string> = {
  Beginner: 'bg-emerald-100 text-emerald-700',
  Intermediate: 'bg-amber-100 text-amber-700',
  Advanced: 'bg-purple-100 text-purple-700',
};

/* ── JSON-LD ── */
const siteUrl = 'https://hedgeflows.com';

const collectionSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'FX & Treasury Academy',
  description: 'Free, in-depth guides on foreign exchange, currency management, and hedging strategies for growing businesses.',
  url: `${siteUrl}/fx-academy`,
  publisher: {
    '@type': 'Organization',
    name: 'HedgeFlows',
    logo: { '@type': 'ImageObject', url: `${siteUrl}/logos/hf-logo-green.svg` },
  },
  mainEntity: {
    '@type': 'ItemList',
    itemListElement: guides.map((g, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      url: `${siteUrl}/fx-academy/${g.slug}`,
      name: g.title,
    })),
  },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: 'FX Academy', item: `${siteUrl}/fx-academy` },
  ],
};
---

<PageLayout
  title="FX & Treasury Academy | HedgeFlows"
  description="Free, in-depth guides on foreign exchange, currency management, and hedging strategies for growing businesses. Learn FX fundamentals, build a hedging programme, and manage currency risk."
>
  <script type="application/ld+json" set:html={JSON.stringify(collectionSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <Hero
    title="FX & Treasury Academy"
    subtitle="Free, in-depth guides to help you understand foreign exchange, manage currency risk, and build treasury best practices. Written by experts with 40+ years of institutional experience."
  />

  <!-- Guides Section -->
  <section class="section-padding">
    <div class="container-content">
      {/* Learning path intro */}
      <div class="max-w-3xl mx-auto text-center mb-14">
        <p class="text-[1.0625rem] text-text-body leading-relaxed">
          Nine guides taking you from FX fundamentals to building a complete hedging programme. Start anywhere — each guide stands alone — or follow the path from beginner to advanced.
        </p>
      </div>

      {/* Guide cards */}
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
        {guides.map((guide, i) => (
          <a
            href={`/fx-academy/${guide.slug}`}
            class="group block bg-white rounded-xl border border-gray-100 overflow-hidden
                   shadow-[0_1px_3px_rgba(0,0,0,0.04),0_6px_24px_rgba(0,0,0,0.04)]
                   hover:shadow-[0_4px_12px_rgba(0,0,0,0.06),0_12px_40px_rgba(0,0,0,0.06)]
                   hover:border-brand-green/20 transition-all duration-300 flex flex-col"
          >
            {/* Number header */}
            <div class="bg-gradient-to-br from-brand-green-pale to-brand-green/10 px-6 pt-6 pb-4 flex items-center justify-between">
              <span class="text-[2.5rem] font-bold text-brand-green/20 leading-none">
                {String(i + 1).padStart(2, '0')}
              </span>
              <span class:list={['text-[0.6875rem] font-bold uppercase tracking-wider px-2.5 py-1 rounded-full', levelColors[guide.level]]}>
                {guide.level}
              </span>
            </div>

            <div class="p-6 flex flex-col flex-1">
              <h3 class="text-[1.125rem] font-semibold text-text-heading
                         group-hover:text-brand-green transition-colors duration-200 leading-snug mb-2">
                {guide.title}
              </h3>
              <p class="text-[0.9375rem] text-text-body leading-relaxed flex-1 mb-4">
                {guide.description}
              </p>
              <div class="flex items-center justify-between">
                <span class="text-[0.8125rem] text-text-muted">{guide.readingTime}</span>
                <span class="inline-flex items-center gap-1.5 text-brand-green font-semibold text-[0.8125rem] group-hover:gap-2.5 transition-all duration-200">
                  Read guide
                  <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                  </svg>
                </span>
              </div>
            </div>
          </a>
        ))}
      </div>

      {/* Credentials */}
      <div class="max-w-3xl mx-auto mt-16 text-center">
        <p class="text-[0.9375rem] text-text-muted leading-relaxed">
          Written by the HedgeFlows advisory team — 40+ years of institutional FX and treasury experience from Standard Chartered, Merrill Lynch, and Bank of America. FCA regulated (Firm Reference: 1008699).
        </p>
      </div>
    </div>
  </section>

  <!-- Related Articles -->
  {pillarPosts.length > 0 && (
    <section class="section-padding bg-[#F8FAFB]">
      <div class="container-content">
        <div class="text-center mb-14">
          <h2 class="section-heading">Related Articles</h2>
          <p class="section-subheading mx-auto">
            Practical insights on FX hedging, currency risk, and international finance from the HedgeFlows team.
          </p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
          {pillarPosts.map((post) => (
            <BlogCard
              title={post.data.title}
              excerpt={post.data.description}
              date={post.data.date}
              href={`/blog/${post.data.slug}`}
              image={post.data.featuredImage}
              category={post.data.category}
            />
          ))}
        </div>

        <div class="text-center mt-10">
          <a href="/blog" class="inline-flex items-center gap-2 text-brand-green font-semibold hover:gap-3 transition-all">
            View all articles
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- Key Terms Explained -->
  {glossaryTerms.length > 0 && (
    <section class="section-padding bg-white">
      <div class="container-content">
        <div class="text-center mb-10">
          <h2 class="section-heading">Key Terms Explained</h2>
          <p class="section-subheading mx-auto">
            Clear definitions of the FX and hedging terminology you need to know.
          </p>
        </div>

        <div class="flex flex-wrap justify-center gap-3 max-w-3xl mx-auto">
          {glossaryTerms.map((term) => (
            <a
              href={`/glossary/${term.data.slug}`}
              class="inline-flex items-center gap-1.5 px-4 py-2 rounded-full
                     bg-brand-green-pale/50 text-text-heading text-[0.875rem] font-medium
                     border border-brand-green/10 hover:border-brand-green/30
                     hover:bg-brand-green-pale transition-all duration-200"
            >
              {term.data.term}
            </a>
          ))}
        </div>

        <div class="text-center mt-8">
          <a href="/glossary" class="inline-flex items-center gap-2 text-brand-green font-semibold text-[0.875rem] hover:gap-3 transition-all">
            Browse full glossary
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- Practical Resources -->
  <section class="section-padding bg-[#F8FAFB]">
    <div class="container-content">
      <div class="text-center mb-10">
        <h2 class="section-heading">Practical Resources</h2>
        <p class="section-subheading mx-auto">
          Help articles and product features to put your FX knowledge into practice.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-6 max-w-3xl mx-auto">
        {/* Help articles */}
        {helpPages.length > 0 && (
          <div class="bg-white rounded-2xl border border-gray-100 p-8 shadow-sm">
            <h3 class="text-[1.125rem] font-bold text-text-heading mb-4 flex items-center gap-2">
              <svg class="w-5 h-5 text-brand-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9 5.25h.008v.008H12v-.008z" />
              </svg>
              Help Centre
            </h3>
            <ul class="space-y-3">
              {helpPages.map((page) => (
                <li>
                  <a href={`/help/${page.slug}`} class="text-[0.9375rem] text-text-body hover:text-brand-green transition-colors">
                    {page.title}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}

        {/* Product links */}
        {productLinks.length > 0 && (
          <div class="bg-white rounded-2xl border border-gray-100 p-8 shadow-sm">
            <h3 class="text-[1.125rem] font-bold text-text-heading mb-4 flex items-center gap-2">
              <svg class="w-5 h-5 text-brand-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
              </svg>
              Platform Features
            </h3>
            <ul class="space-y-3">
              {productLinks.map((link) => (
                <li>
                  <a href={link.href} class="group flex items-center justify-between text-[0.9375rem] text-text-body hover:text-brand-green transition-colors">
                    {link.label}
                    <svg class="w-4 h-4 text-gray-300 group-hover:text-brand-green transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                    </svg>
                  </a>
                </li>
              ))}
            </ul>
            <div class="mt-6 pt-4 border-t border-gray-100">
              <a href="/advisory" class="group flex items-center justify-between text-[0.9375rem] text-text-body hover:text-brand-green transition-colors">
                Treasury Advisory Services
                <svg class="w-4 h-4 text-gray-300 group-hover:text-brand-green transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                </svg>
              </a>
            </div>
          </div>
        )}
      </div>
    </div>
  </section>
</PageLayout>
