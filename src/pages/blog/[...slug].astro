---
import PageLayout from '../../layouts/PageLayout.astro';
import { getCollection, render } from 'astro:content';
import { getHubByPillar } from '../../data/hubPages';
import { getBlogPosts, getBlogPost, urlFor } from '../../lib/sanity';
import PortableText from '../../components/PortableText.astro';

export async function getStaticPaths() {
  // Markdown posts
  const mdEntries = await getCollection('blog');
  const mdPaths = mdEntries.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { source: 'md' as const, mdPost: entry, sanitySlug: null },
  }));

  // Sanity posts — skip any slugs already covered by Markdown
  let sanityPaths: any[] = [];
  try {
    const sanityEntries = await getBlogPosts();
    const mdSlugs = new Set(mdEntries.map((e) => e.data.slug));
    sanityPaths = (sanityEntries || [])
      .filter((p: any) => p.slug?.current && !mdSlugs.has(p.slug.current))
      .map((p: any) => ({
        params: { slug: p.slug.current },
        props: { source: 'sanity' as const, mdPost: null, sanitySlug: p.slug.current },
      }));
  } catch {
    // No Sanity posts yet — that's fine
  }

  return [...mdPaths, ...sanityPaths];
}

/* ── Normalise post data from whichever source ── */
const { source, mdPost, sanitySlug } = Astro.props;

let title = '';
let date = '';
let description = '';
let authorName: string | undefined;
let featuredImageUrl: string | undefined;
let category: string | undefined;
let seoTitle: string | undefined;
let slug = '';
let pillar: string | undefined;
let Content: any = null;
let sanityBody: any = null;
let updated: string | undefined;

if (source === 'md' && mdPost) {
  const { Content: MdContent } = await render(mdPost);
  Content = MdContent;
  title = mdPost.data.title;
  date = mdPost.data.date;
  description = mdPost.data.description || '';
  authorName = mdPost.data.author;
  featuredImageUrl = mdPost.data.featuredImage;
  category = mdPost.data.category;
  seoTitle = mdPost.data.seoTitle;
  slug = mdPost.data.slug;
  pillar = mdPost.data.pillar;
  updated = mdPost.data.updated;
} else {
  const post = await getBlogPost(sanitySlug!);
  title = post?.title || '';
  date = post?.publishedAt || new Date().toISOString();
  description = post?.excerpt || post?.seoDescription || '';
  authorName = post?.author?.name;
  featuredImageUrl = post?.featuredImage
    ? urlFor(post.featuredImage).width(768).height(432).auto('format').url()
    : undefined;
  category = post?.tags?.[0];
  seoTitle = post?.seoTitle;
  slug = sanitySlug!;
  sanityBody = post?.body;
}

const hub = pillar ? getHubByPillar(pillar) : undefined;

const categoryLabels: Record<string, string> = {
  'fx-risk-hedging': 'FX Risk & Hedging',
  'treasury-cash': 'Treasury & Cash Management',
  'payments-ops': 'Payments & Operations',
  'markets': 'Market Commentary',
  'news': 'Company News',
};

const categoryColors: Record<string, string> = {
  'fx-risk-hedging': 'bg-emerald-50 text-emerald-700',
  'treasury-cash': 'bg-sky-50 text-sky-700',
  'payments-ops': 'bg-violet-50 text-violet-700',
  'markets': 'bg-amber-50 text-amber-700',
  'news': 'bg-rose-50 text-rose-700',
};

const formattedDate = new Date(date).toLocaleDateString('en-GB', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const siteUrl = 'https://hedgeflows.com';
const pageUrl = `${siteUrl}/blog/${slug}`;

// BlogPosting structured data
const blogPostingSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": title,
  "description": description,
  "datePublished": date,
  "dateModified": updated || date,
  "author": {
    "@type": "Person",
    "name": authorName || "HedgeFlows",
  },
  "publisher": {
    "@type": "Organization",
    "name": "HedgeFlows",
    "logo": {
      "@type": "ImageObject",
      "url": `${siteUrl}/logos/hf-logo-green.svg`,
    },
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": pageUrl,
  },
  ...(featuredImageUrl ? { "image": featuredImageUrl } : {}),
};

// BreadcrumbList structured data
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": siteUrl,
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Blog",
      "item": `${siteUrl}/blog`,
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": title,
      "item": pageUrl,
    },
  ],
};
---

<PageLayout
  title={seoTitle || title}
  description={description}
  ogImage={featuredImageUrl}
  ogType="article"
>
  {/* Structured Data */}
  <script type="application/ld+json" set:html={JSON.stringify(blogPostingSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <article class="section-padding bg-white">
    <div class="container-content max-w-3xl mx-auto">
      {/* Breadcrumb */}
      <nav class="mb-8 text-[0.875rem] text-text-muted" aria-label="Breadcrumb">
        <a href="/blog" class="hover:text-brand-green transition-colors">Blog</a>
        <span class="mx-2">/</span>
        <span class="text-text-heading font-medium">{title}</span>
      </nav>

      {/* Title & meta */}
      <h1 class="text-[2rem] md:text-[2.75rem] font-bold text-text-heading leading-tight mb-4">
        {title}
      </h1>

      <div class="flex flex-wrap items-center gap-3 text-[0.8125rem] text-text-muted mb-10">
        <time datetime={date}>{formattedDate}</time>
        {authorName && (
          <>
            <span>·</span>
            <span>by {authorName}</span>
          </>
        )}
        {category && categoryLabels[category] && (
          <>
            <span>·</span>
            <span class:list={[
              'text-[0.6875rem] font-bold uppercase tracking-wider px-2.5 py-0.5 rounded-full',
              categoryColors[category] || 'bg-gray-100 text-gray-600'
            ]}>
              {categoryLabels[category]}
            </span>
          </>
        )}
      </div>

      {/* Featured image */}
      {featuredImageUrl && (
        <img
          src={featuredImageUrl}
          alt={title}
          width="768"
          height="432"
          class="w-full rounded-xl shadow-md mb-10"
          loading="eager"
          decoding="async"
          fetchpriority="high"
        />
      )}

      {/* Main content */}
      <div class="prose-blog">
        {Content ? <Content /> : <PortableText value={sanityBody} />}
      </div>

      {/* Pillar back-link */}
      {hub && (
        <div class="mt-10 mb-4 flex items-center gap-3 px-5 py-4 rounded-xl bg-brand-green-pale/40 border border-brand-green/10">
          <svg class="w-5 h-5 text-brand-green flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.331 0 4.467.89 6.064 2.346m0-12.304a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.346m0-12.304v12.304" />
          </svg>
          <span class="text-[0.9375rem] text-text-body">
            Part of our{' '}
            <a href={hub.path} class="text-brand-green font-semibold hover:underline">
              {hub.linkLabel}
            </a>
          </span>
        </div>
      )}

      {/* Advisory CTA */}
      <div class="mt-14 bg-brand-green-pale/50 rounded-2xl p-8 border border-brand-green/10">
        <p class="text-[1.0625rem] text-text-body leading-relaxed mb-4">
          Need help managing your international finances? Our advisory team can help you build a treasury strategy that fits your business.
        </p>
        <a
          href="/advisory"
          class="inline-flex items-center gap-2 bg-brand-green text-white font-semibold px-6 py-3 rounded-full text-[0.875rem] shadow-sm hover:bg-brand-green-dark hover:shadow-md transition-all duration-200"
        >
          Book a Treasury Review
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
      </div>

      {/* Back link */}
      <div class="mt-10">
        <a href="/blog" class="inline-flex items-center gap-2 text-brand-green font-semibold hover:gap-3 transition-all">
          <svg class="w-4 h-4 rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
          Back to Blog
        </a>
      </div>
    </div>
  </article>
</PageLayout>

<style is:global>
  /* Blog prose styles */
  .prose-blog h2 {
    @apply text-[1.5rem] font-bold text-text-heading mt-12 mb-4 leading-tight;
  }
  .prose-blog h3 {
    @apply text-[1.25rem] font-bold text-text-heading mt-8 mb-3;
  }
  .prose-blog h4 {
    @apply text-[1.125rem] font-semibold text-text-heading mt-6 mb-2;
  }
  .prose-blog p {
    @apply text-[1.0625rem] text-text-body leading-relaxed mb-4;
  }
  .prose-blog ul, .prose-blog ol {
    @apply text-[1.0625rem] text-text-body leading-relaxed mb-4 pl-6;
  }
  .prose-blog ul { @apply list-disc; }
  .prose-blog ol { @apply list-decimal; }
  .prose-blog li { @apply mb-2; }
  .prose-blog strong { @apply text-text-heading font-semibold; }
  .prose-blog a {
    @apply text-brand-green underline underline-offset-2 hover:text-brand-green-dark transition-colors;
  }
  .prose-blog blockquote {
    @apply border-l-4 border-brand-green/30 pl-6 italic text-text-muted my-6;
  }
  .prose-blog table {
    @apply w-full border-collapse mb-6 text-[0.9375rem];
  }
  .prose-blog thead th {
    @apply bg-[#F8FAFB] text-text-heading font-semibold text-left px-4 py-3 border border-gray-200;
  }
  .prose-blog tbody td {
    @apply px-4 py-3 border border-gray-200 text-text-body;
  }
  .prose-blog img {
    @apply rounded-xl my-6 max-w-full;
  }
  .prose-blog hr {
    @apply my-8 border-gray-200;
  }
</style>
