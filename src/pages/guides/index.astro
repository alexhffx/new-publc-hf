---
import PageLayout from '../../layouts/PageLayout.astro';
import Hero from '../../components/Hero.astro';

const guides = [
  {
    title: 'FX & Treasury Academy',
    description: 'Nine in-depth guides on FX fundamentals, currency management, and hedging strategies — from beginner to advanced.',
    href: '/fx-academy',
    icon: 'M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5',
    badge: '9 guides',
  },
  {
    title: 'International Bulk Payments',
    description: 'How to process cross-border payment runs faster, cut hidden FX fees, and eliminate manual errors at scale.',
    href: '/guides/international-bulk-payments',
    icon: 'M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 0 1 3 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 0 0-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 0 1-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 0 0 3 15h-.75M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm3 0h.008v.008H18V10.5Zm-12 0h.008v.008H6V10.5Z',
    badge: 'Guide',
  },
  {
    title: 'Treasury Management',
    description: 'Build the cash management, risk oversight, and financial planning capabilities your growing business needs.',
    href: '/guides/treasury-management',
    icon: 'M3.75 3v11.25A2.25 2.25 0 0 0 6 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0 1 18 16.5h-2.25m-7.5 0h7.5m-7.5 0-1 3m8.5-3 1 3m0 0 .5 1.5m-.5-1.5h-9.5m0 0-.5 1.5m.75-9 3-3 2.148 2.148A12.061 12.061 0 0 1 16.5 7.605',
    badge: 'Guide',
  },
];

const siteUrl = 'https://hedgeflows.com';

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: 'Guides', item: `${siteUrl}/guides` },
  ],
};
---

<PageLayout
  title="Guides | HedgeFlows"
  description="In-depth guides on FX hedging, currency management, international payments, and treasury management for growing businesses."
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <Hero
    title="Guides & Resources"
    subtitle="In-depth guides to help you master foreign exchange, international payments, and treasury management. Written by experts with decades of institutional experience."
  />

  <section class="section-padding">
    <div class="container-content">
      <div class="grid md:grid-cols-3 gap-6 lg:gap-8 max-w-5xl mx-auto">
        {guides.map((guide) => (
          <a
            href={guide.href}
            class="group block bg-white rounded-2xl border border-gray-100 p-8
                   shadow-[0_1px_3px_rgba(0,0,0,0.04),0_6px_24px_rgba(0,0,0,0.04)]
                   hover:shadow-[0_4px_12px_rgba(0,0,0,0.06),0_12px_40px_rgba(0,0,0,0.06)]
                   hover:border-brand-green/20 transition-all duration-300 flex flex-col"
          >
            <div class="flex items-center gap-3 mb-4">
              <div class="w-10 h-10 rounded-lg bg-brand-green-pale flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-brand-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d={guide.icon} />
                </svg>
              </div>
              <span class="text-[0.6875rem] font-bold uppercase tracking-wider text-brand-green bg-brand-green-pale/50 px-2.5 py-1 rounded-full">
                {guide.badge}
              </span>
            </div>

            <h2 class="text-[1.25rem] font-bold text-text-heading group-hover:text-brand-green transition-colors mb-3 leading-snug">
              {guide.title}
            </h2>

            <p class="text-[0.9375rem] text-text-body leading-relaxed flex-1 mb-4">
              {guide.description}
            </p>

            <span class="inline-flex items-center gap-1.5 text-brand-green font-semibold text-[0.875rem] group-hover:gap-2.5 transition-all duration-200">
              Explore
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>
</PageLayout>
