          <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
        </svg>
        <a href="/help/#fx-trading" class="hover:text-brand-green transition-colors">FX & Currency</a>
      </nav>

      <h1 class="text-[1.75rem] md:text-[2.25rem] font-bold text-text-heading leading-tight mb-8">What is a position closeout?</h1>

