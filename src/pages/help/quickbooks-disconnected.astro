---
import PageLayout from '../../layouts/PageLayout.astro';
---

<PageLayout
  title="QuickBooks Disconnected | HedgeFlows"
  description="Your QuickBooks integration has been disconnected from HedgeFlows. Learn how to reconnect."
>
  <section class="py-16 md:py-24">
    <div class="mx-auto max-w-2xl px-4 sm:px-6 text-center">
      <div class="w-16 h-16 rounded-full bg-amber-50 flex items-center justify-center mx-auto mb-6">
        <svg class="w-8 h-8 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244" />
        </svg>
      </div>

      <h1 class="text-[1.75rem] md:text-[2.25rem] font-bold text-text-heading mb-6">QuickBooks Disconnected</h1>

      <div class="bg-brand-green-pale rounded-2xl border border-brand-green/10 p-8 md:p-10 text-left space-y-4 mb-10">
        <p class="text-[0.9375rem] text-text-body leading-relaxed">
          Your QuickBooks integration has been disconnected. You will no longer be able to sync invoices, bills or payments between your QuickBooks account and HedgeFlows.
        </p>
        <p class="text-[0.9375rem] text-text-body leading-relaxed">
          If you'd like to re-connect QuickBooks and HedgeFlows, visit our <a href="/help/quickbooks-integration-how-to-get-started" class="text-brand-green font-semibold hover:underline">help guide here</a>.
        </p>
        <p class="text-[0.9375rem] text-text-body leading-relaxed">
          For general support, <a href="/contact" class="text-brand-green font-semibold hover:underline">contact us</a> or visit the <a href="/help" class="text-brand-green font-semibold hover:underline">Help Centre</a>.
        </p>
      </div>

      <a href="/help/quickbooks-integration-how-to-get-started" class="btn-primary inline-flex items-center gap-2 text-[1rem] px-8 py-3.5">
        Reconnect QuickBooks
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
    </div>
  </section>
</PageLayout>
