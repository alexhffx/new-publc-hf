---

<PageLayout
  title="Help Centre | HedgeFlows"
  description="Find answers to common questions about HedgeFlows — payments, integrations, FX trading, and getting started."
>
  <!-- Hero -->
  <section class="bg-gradient-to-b from-brand-green-pale to-white py-16 md:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-text-heading">Help Centre</h1>
      <p class="mt-4 text-lg text-text-body max-w-2xl mx-auto">
        Everything you need to know about using HedgeFlows — from getting started to managing payments and integrations.
      </p>
    </div>
  </section>

  <!-- Categories -->
  <section class="py-16 md:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6">
      <div class="grid md:grid-cols-2 gap-8">
        {categories.map((cat) => (
          <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden" id={cat.id}>
            <div class="px-6 py-5 border-b border-gray-100 flex items-center gap-3">
              <div class="w-10 h-10 rounded-xl bg-brand-green-pale flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-brand-green" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <Fragment set:html={cat.icon} />
                </svg>
              </div>
              <h2 class="text-lg font-semibold text-text-heading">{cat.title}</h2>
              <span class="ml-auto text-xs font-medium text-text-muted bg-gray-100 rounded-full px-2.5 py-1">{cat.articles.length}</span>
            </div>
            <ul class="divide-y divide-gray-50">
              {cat.articles.map((article) => (
                <li>
                  <a
                    href={`/help/${article.slug}`}
                    class="flex items-center gap-3 px-6 py-3.5 text-[0.9375rem] text-text-body hover:bg-brand-green-pale/30 hover:text-brand-green transition-colors duration-150"
                  >
                    <svg class="w-4 h-4 text-gray-300 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
                    </svg>
                    {article.title}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      <!-- Contact -->
      <div class="mt-12 text-center">
        <p class="text-text-body">
          Can't find what you're looking for?
          <a href="mailto:support@hedgeflows.com" class="text-brand-green font-medium hover:underline">Contact support</a>
        </p>
      </div>
    </div>
  </section>
</PageLayout>
