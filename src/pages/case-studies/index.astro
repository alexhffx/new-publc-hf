---
import PageLayout from '../../layouts/PageLayout.astro';
import Hero from '../../components/Hero.astro';

const caseStudies = [
  {
    slug: 'premium-travel-brand',
    clientName: 'Premium Travel Brand',
    industry: 'Travel',
    pillars: ['Risk Management', 'Digitalisation'],
    pullQuote: 'It definitely saves us time, having completely removed the need to manually track hedges, and the annoyance of setting up payments in the bank.',
    stats: ['50 days/year saved', '5x faster approvals', '92% error reduction'],
  },
  {
    slug: 'moteefe',
    clientName: 'Moteefe',
    industry: 'E-Commerce',
    pillars: ['Digitalisation', 'Cash Management'],
    pullQuote: 'Managing FX and payments is always tricky but HedgeFlows really help. Definitely a key part of the Xero tech stack.',
    stats: ['70% time savings', '50% fee reduction'],
  },
  {
    slug: 'signify-technology',
    clientName: 'Signify Technology',
    industry: 'Staffing & Recruitment',
    pillars: ['Digitalisation'],
    pullQuote: 'HedgeFlows has significantly helped us with our continued goal of increasing efficiency within the Finance Department.',
  },
  {
    slug: 'jbm',
    clientName: 'JBM Freight',
    industry: 'Logistics',
    pillars: ['Digitalisation', 'Cash Management'],
    pullQuote: "Being able to pull the invoices and just pay them directly with HedgeFlows is great. It's not a challenge anymore.",
  },
  {
    slug: 'zygo',
    clientName: 'Zygo',
    industry: 'Logistics',
    pillars: ['Risk Management', 'Digitalisation'],
    pullQuote: 'HedgeFlows gave us the autonomy and the visibility into the moving market to understand our exposure and risk.',
  },
  {
    slug: 'cable-analytics',
    clientName: 'Cable Analytics',
    industry: 'Startups & Scaleups',
    pillars: ['Risk Management'],
    pullQuote: 'HedgeFlows is much more competitive and give us the stability we need. Whenever we need support, we get it straightaway.',
  },
  {
    slug: 'gymnamo',
    clientName: 'Gymnamo',
    industry: 'E-Commerce',
    pillars: ['Risk Management'],
    pullQuote: 'HedgeFlows gave me the autonomy I needed. No more calls from FX brokers \u2014 the last order saved me 7%.',
  },
];
---

<PageLayout title="Case Studies | HedgeFlows" description="See how HedgeFlows helps international businesses optimise treasury and FX.">
  <Hero
    title="Real results for real businesses"
    subtitle="See how we've helped international businesses take control of treasury, reduce FX costs, and manage risk."
  />
  <section class="section-padding">
    <div class="container-content">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8">
        {caseStudies.map((cs) => (
          <a
            href={`/case-studies/${cs.slug}`}
            class="group block bg-white rounded-xl border border-gray-100 overflow-hidden
                   shadow-[0_1px_3px_rgba(0,0,0,0.04),0_6px_24px_rgba(0,0,0,0.04)]
                   hover:shadow-[0_4px_12px_rgba(0,0,0,0.06),0_12px_40px_rgba(0,0,0,0.06)]
                   transition-all duration-300"
          >
            <div class="w-full aspect-[2/1] bg-gradient-to-br from-brand-green-pale to-brand-green/10 flex items-center justify-center">
              <span class="text-[2rem] font-bold text-brand-green/20">{cs.clientName}</span>
            </div>
            <div class="p-6 md:p-7">
              {/* Tags */}
              <div class="flex flex-wrap gap-2 mb-3">
                <span class="px-2.5 py-0.5 bg-brand-green-pale text-brand-green text-[0.75rem] font-semibold rounded-full">
                  {cs.industry}
                </span>
                {cs.pillars.map((p: string) => (
                  <span class="px-2.5 py-0.5 bg-gray-100 text-text-muted text-[0.75rem] font-medium rounded-full">
                    {p}
                  </span>
                ))}
              </div>

              <h3 class="text-[1.25rem] font-semibold text-text-heading
                         group-hover:text-brand-green transition-colors duration-200 leading-snug mb-3">
                {cs.clientName}
              </h3>

              <p class="text-[0.9375rem] text-text-body leading-relaxed italic line-clamp-2">
                &ldquo;{cs.pullQuote}&rdquo;
              </p>

              {cs.stats && (
                <div class="flex flex-wrap gap-2 mt-3">
                  {cs.stats.map((stat: string) => (
                    <span class="px-2 py-0.5 bg-brand-green/5 text-brand-green text-[0.75rem] font-medium rounded">
                      {stat}
                    </span>
                  ))}
                </div>
              )}

              <span class="inline-flex items-center gap-1.5 text-brand-green font-semibold text-[0.875rem] mt-4
                           group-hover:gap-2.5 transition-all duration-200">
                Read case study
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                </svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</PageLayout>
